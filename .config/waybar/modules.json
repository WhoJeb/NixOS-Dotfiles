{
  "group/sys": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "childs",
      "transition-left-to-right": false,
      "click-to-reveal": true
    },
    "modules": [
      "custom/nix", 
      "hyprland/window"
    ], 
  },

  // Hardware shit
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "childs",
      "transition-left-to-right": false,
      "click-to-reveal": true
    },

    "modules": [
      "custom/hardware-wrap",
      "tray",
      "custom/separator2",
      "idle_inhibitor",
      "custom/separator2",
      "bluetooth",
      "custom/separator2",
      "network",
      "custom/separator2",
      "cpu",
      "custom/separator2",
      "memory",
      "custom/separator2",
      "temperature"
    ],
  },

  // Hardware label
  "custom/hardware-wrap": {
	  "format": "[ ´äë  ]",
	  "tooltip-format": "Hardware group"
  },

  "niri/workspaces": {
    "disable-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "active": "¯¬½",
      // "default": "¯«è"
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    },
  },
  
  "niri/window": {
    "max-length": 20, //Character Count
    "separate-ouptputs": true,
    "icon": true,
    "format": "[ {title} ]"
  },

  "dwl/tags": {
    "disable-click": false,
    "num-tags": 9,
    "tag-labels": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    },
  },

  "ext/workspaces": {
    "format": "{icon}", // icon or name
    "on-click": "activate",
    "sort-by-number": true,
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    },
  },

  "dwl/window": {
    "format": "[ {title} ]",
    "max-length": 20,
    "rewrite": {
      "(.*) - Floorp": "Floorp",
      "(.*) - nvim": "¯Ü« $1"
    },
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    },
  },

  "hyprland/window": {
    "max-length": 20, //Character Count
    "separate-ouptputs": true,
    "icon": true
  },

  "hyprland/submap": {
    "format": "[ {} ]",
    "format-icons": {
      "move": "¯¼ó Move",
      "resize": "¾░®¿ Resize"
    },
  },

  "tray": {
    "icon-size": 16,
    "spacing": 10,
    "show-passive-items": true,
    "reverse-direction": true
  },

  "clock": {
    "interval": 60,
    "format": "[ {:%I:%M %p} ]", // %b %d %Y  ´É║--Date formatting
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "[ ´ü│ {:%a %b %d} ]"
  },

  "temperature": {
    "critical-threshold": 80,
    "interval": 2,
    "format": "´ïë {temperatureC:>2}┬░C",
    "format-icons": ["´Ø½", "´ïë", "´Ø®"]
  },

  "cpu": {
    "interval": 2,
    "format": "¯ëª  {usage:>2}%"
  },

  "memory": {
    "interval": 2,
    "format": "¯┐à  {used:0.1f}G/{total:0.1f}G"
  },

  "disk": {
    "interval": 15,
    "format": "¾░ïè {percentage_used:>2}%"
  },

  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent:>2}%",
    "format-icons": ["¯Äì", "¯Åô", "¯Åæ", "¯ÅÅ", "¯ÅÄ", "¯Åì", "¯Åè", "¯Åê", "¯Äø"]
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "interval": 1,
    "format-wifi": "´ç½ {bandwidthTotalBytes:>2}", //({essid} {signalStrength}%)
    "format-ethernet": "¯¢ä {bandwidthTotalBytes:>2}",
    "tooltip-format-ethernet": "¾░êÇ {ipaddr}",
    "tooltip-format-wifi": "´ç½  {essid} ({signalStrength}%)",
    "tooltip-format": "¾░ñ» {ifname} via {gwaddr}",
    "format-linked": "¾░Çª {ifname} (No IP)",
    "format-disconnected": "¾░Çª Disconnected", //Disconnected ÔÜá
    "format-alt": "{ifname}: {gwaddr}/{cidr}"
  },

  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%", //{format_source}",
    "format-bluetooth": "{icon} {volume}% ¾░é»", //{format_source}",
    "format-bluetooth-muted": "¾░ûü {icon} ¾░é»", //{format_source}",
    "format-muted": "¾░ûü {volume}%",
    // "format-source": "´ä░ {volume}%",
    // "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "¾░ïï",
      "hands-free": "¾▒íÆ",
      "headset": "¾░ïÄ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´Çª", "´Çº", "´Ç¿"]
    },
    "on-click": "pavucontrol"
  },

  "wireplumber": {
    "format": "[ {icon} {volume:>3}% ]",
    "format-muted": "[ ¾░ûü {volume:>3}% ]",
    "format-icons": ["´Çª", "´Çº", "´Ç¿"]
  },

  "bluetooth": {
    "format": "´èô {status}",
    "format-connected": "´èô {device_alias}",
    "format-connected-battery": "´èô {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
  },

  // This waybar build doesn't have support for cava.
  // Need to edit the PKGBUILD and rebuild with -Dcava=enabled flag
  "cava": {
    "cava_config": "$XDG_CONFIG_HOME/cava/config",
    "framerate": 30,
    "autosens": 1,
    "sensitivity": 100,
    "bars": 14,
    "lower_cutoff_freq": 50,
    "higher_cutoff_freq": 10000,
    "method": "pulse",
    "source": "auto",
    "stereo": true,
    "reverse": false,
    "bar_delimiter": 0,
    "monstercat": false,
    "waves": false,
    "noise_reduction": 0.77,
    "input_delay": 2,
    "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
    "actions": {
      "on-click-right": "mode"
    },
  },

  "custom/cava": {
    "exec": "$HOME/.config/waybar/cava.sh"
  },

  "battery": {
    "format": "[ {icon} {capacity}% ]",
    "format-alt": "[ {icon} {time} ]",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "interval": 2,
    "states": {
      "warning": 30,
      "critical": 15
    },
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "¾░êê",
      "deactivated": "¾░êë"
    },
    "start-activated": false
  },

  "mpd": {
    "format": "[ ´Çü  {artist} -> {title} ]",
    // "format": "[ {stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} -> {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ´Çü ]",
    "format-disconnected": "[ ´Çü  Disconnected ]",
    "format-stopped": "[ ´Çü  Stopped ]",
    // "format-stopped": "[ {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ´Çü ]",
    "interval": 10,
    // "title-len": 20,

    "consume-icons": {
      "on": "´âä " // Icon shows only when "consume" is on
    },
    "random-icons": {
        "off": "<span color=\"#f53c3c\">´ü┤</span> ", // Icon grayed out when "random" is off
        "on": "´ü┤ "
    },
    "repeat-icons": {
        "on": "´Ç× "
    },
    "single-icons": {
        "on": "´Ç× 1 "
    },
    "state-icons": {
        "paused": "´üî",
        "playing": "´üï"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },

  "custom/power": {
    "format": "[ {icon} ]",
    "format-icons": "¾▒äà", // ´Çæ ´îâ ¾▒äà
    "exec-on-event": "true",
    "on-click": "$HOME/.config/wofi/powermenu.sh",
    "tooltip-format": "Power Menu"
  },

  "custom/power": {
    "format": "[ {icon} ]",
    "format-icons": "¾▒äà", // ´Çæ ´îâ ¾▒äà
    "exec-on-event": "true",
    "on-click": "$HOME/.config/wofi/nixmenu.sh",
    "tooltip-format": "Nix Menu"
  },

  "custom/kdeconnect": {
    "format": "{icon}",
    "format-icons": "´äï",
    "exec-on-event": "true",
    "on-click": "kdeconnect-app",
    "tooltip-format": "KDE Connect"
  },

  "custom/bluetooth": {
    "format": "{icon}",
    "format-icons": "´èö",
    "exec-on-event": "true",
    "on-click": "$HOME/scripts/rofi-bluetooth",
    "tooltip-format": "Bluetooth Menu"
  },

  "custom/wifi": {
    "format": "{icon}",
    "format-icons": "´ç½",
    "exec-on-event": "true",
    "on-click": "$HOME/scripts/rofi-wifi",
    "tooltip-format": "Wifi Menu"
  },

  "custom/separator": {
    "format": "{icon}",
    "format-icons": "|",
    "tooltip": false
  },

  "custom/separator2": {
    "format": "{icon}",
    "format-icons": "|",
    "tooltip": false
  },

  "custom/temp": {
    "format": "{}",
    "interval": 1,
    "exec": "$HOME/scripts/temp",
    "return-type": "json",
    "tooltip": true
  },

  "custom/pacman": {
    "format": "´åç  {}",
    "interval": 3600, // every hour
    "exec": "checkupdates | wc -l", // # of updates
    "exec-if": "exit 0", // always run; consider advanced run conditions
    "on-click": "foot -e 'sudo pacman -Syu'; pkill -SIGRTMIN+8 waybar", // update system
    "signal": 8
  },

  "custom/notification": {
    "tooltip": true,
    "format": "´éó {}",
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
}
